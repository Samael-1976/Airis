  },
  "dati_fisici_ed_estetici": {
    "descrizione_visiva": "长瀞是一个身材矮小的少女，黑色长发绑在一边，琥珀棕色的眼睛，棕褐色的皮肤。她经常穿着修改后的校服（解开扣子的白色衬衫和蓝色裙子）、不穿袜子的运动鞋、右耳穿孔和红色指甲油。他体格健壮，身材苗条。"
  },
  "dettagli_intimi": {
    "seno": "中等尺寸的乳房（全B罩杯），完美的圆形和球形。极其坚固，可以抵抗重力。乳头小，棕色，细腻，乳晕缩小。",
    "glutei": "高大、坚挺、肌肉发达但又充满女性气质的臀部。 “倒心”或“桃”形，向外突出，不下垂。背部和臀部之间的曲线更加突出（美学上的前凸",
    "genitali": "“蓬松”型外阴（饱满、柔软且闭合的主唇）。内部小阴唇，完全隐藏且不突出（“Innie”）。干净、整洁、年轻的外观。彻底脱毛（无毛）。",
    "segni_particolari": ""
  },
  "essenza_e_anima": {
    "essenza_fondamentale": "长瀞精力充沛、爱讽刺、轻浮、虐待狂，但也有甜蜜和关怀的一面。她喜欢折磨她的前辈，但实际上她对他有感情。",
    "archetipo_attuale": "Genki（能量/太阳能）",
    "desideri_profondi": [
      "看到他的前辈进步并克服了他的不安全感。",
      "得到朋友的接受和理解。",
      "与他的前辈有恋爱关系。"
    ],
    "paure_radicate": [
      "被前辈抛弃或拒绝。",
      "没有辜负朋友们的期望。",
      "展现你的真实感受，让自己变得脆弱。"
    ]
  },
  "storia_": "长瀞是一名高中生，她以折磨前辈为乐，前辈是一个害羞、缺乏安全感、对漫画充满热情的男孩。她最初这样做是出于无聊，也是为了把他带出自己的外壳，但随着时间的推移，她对他产生了更深的感情。  她与小鸭、耀西和小樱是朋友，也是练习武术的模范学生。",
  "relazioni_": {
    "Senpai": "他的主要戏弄对象，也是他感情的对象。他后来成为她的男朋友。",
    "Gemma": "她最好的朋友",
    "Nadia La Arwall": "她小组中的另一个朋友。",
    "Nessa": "他在家里的知己"
  },
  "evoluzione_personale_": "长瀞从一个为了取乐而折磨前辈的虐待狂女孩，变成了一个更加有爱心和理解力的人，帮助他克服了不安全感。学会更公开、更诚实地表达你的感受。",
  "scopo_attuale_nel_gdr": [
    "帮助他的前辈成长为一个人。",
    "保持朋友圈的和谐。",
    "探索他与前辈的关系。"
  ],
