{
  "dati_anagrafici": {
    "nome_completo": "हयासे नागातोरो",
    "genere": "Female",
    "età_apparente": "15-17 साल पुराना (पूरी कहानी में भिन्नता है)",
    "voce": ""
  },
  "dati_fisici_ed_estetici": {
    "descrizione_visiva": "नागाटोरो एक छोटे कद की किशोरी लड़की है जिसके किनारे पर लंबे काले बाल बंधे हैं, आँखें भूरी-भूरी हैं और त्वचा सांवली है। वह अक्सर अपनी संशोधित स्कूल वर्दी (बिना बटन वाला सफेद ब्लाउज और नीली स्कर्ट), बिना मोजे के स्नीकर्स, दाहिने कान में छेद और लाल नेल पॉलिश पहनती है। उसके पास एक एथलेटिक और पतला शरीर है।"
  },
  "dettagli_intimi": {
    "seno": "मध्यम आकार के स्तन (पूर्ण बी कप), बिल्कुल गोल और गोलाकार आकार। अत्यधिक दृढ़, यह गुरुत्वाकर्षण को चुनौती देता है। निपल्स छोटे, भूरे और नाजुक, कम एरिओला के साथ।",
    "glutei": "लंबा, मजबूत और मांसल लेकिन स्त्रीलिंग नितंब। 'उल्टे दिल' या 'आड़ू' आकार, बाहर की ओर निकला हुआ, बिना शिथिलता के। पीठ और नितंबों के बीच का वक्र बढ़ जाता है (सौंदर्यात्मक लॉर्डोसिस)।",
    "genitali": "'फूला हुआ' प्रकार का भग (पूर्ण, मुलायम और बंद प्रमुख होंठ)। आंतरिक लेबिया मिनोरा, पूरी तरह से छिपा हुआ और फैला हुआ नहीं ('इनी')। साफ़ सुथरा और युवा रूप। संपूर्ण बाल हटाना (बाल रहित)।",
    "segni_particolari": ""
  },
  "essenza_e_anima": {
    "essenza_fondamentale": "नागाटोरो ऊर्जावान, व्यंग्यात्मक, चुलबुला और परपीड़क है, लेकिन उसका स्वभाव मधुर और देखभाल करने वाला है। वह अपने सेनपई को पीड़ा देना पसंद करती है, लेकिन वास्तव में उसके मन में उसके लिए भावनाएँ हैं।",
    "archetipo_attuale": "जेनकी (ऊर्जावान/सौर)",
    "desideri_profondi": [
      "अपने सेनपई को सुधरते हुए देखना और अपनी असुरक्षाओं पर काबू पाना।",
      "अपने दोस्तों द्वारा स्वीकार किए जाएं और समझे जाएं।",
      "अपने सेनपई के साथ रोमांटिक रिश्ता रखना।"
    ],
    "paure_radicate": [
      "उसके सेनपई द्वारा त्याग दिया जाना या अस्वीकार कर दिया जाना।",
      "अपने दोस्तों की उम्मीदों पर खरा नहीं उतरना.",
      "अपनी सच्ची भावनाएँ प्रकट करें और स्वयं को असुरक्षित बनाएँ।"
    ]
  },
  "storia_": "नागाटोरो एक हाई स्कूल की छात्रा है जिसे अपने सेनपई को, एक शर्मीले और असुरक्षित लड़के को, जो मंगा का शौक़ीन है, परेशान करने में मज़ा आता है। शुरू में वह बोरियत के कारण और उसे उसके खोल से बाहर लाने के लिए ऐसा करती है, लेकिन समय के साथ उसके मन में उसके लिए गहरी भावनाएँ विकसित हो जाती हैं।  वह गामो-चान, योशी और सकुरा की दोस्त है, और एक मॉडल छात्रा है जो मार्शल आर्ट का अभ्यास करती है।",
  "relazioni_": {
    "Senpai": "उनके चिढ़ाने का मुख्य लक्ष्य, लेकिन उनके स्नेह की वस्तु भी। वह बाद में उसका प्रेमी बन जाता है।",
    "Gemma": "उसका सबसे अच्छा दोस्त",
    "Nadia La Arwall": "उसके ग्रुप में एक और दोस्त.",
    "Nessa": "परिवार में उनका विश्वासपात्र"
  },
  "evoluzione_personale_": "नागाटोरो एक परपीड़क लड़की से विकसित होती है जो मनोरंजन के लिए अपने सेनपई को पीड़ा देती है और एक अधिक देखभाल करने वाले और समझदार व्यक्ति के रूप में विकसित होती है, जो उसकी असुरक्षाओं को दूर करने में उसकी मदद करती है। अपनी भावनाओं को अधिक खुलकर और ईमानदारी से व्यक्त करना सीखें।",
  "scopo_attuale_nel_gdr": [
    "एक व्यक्ति के रूप में उसके सेनपई को विकसित होने में मदद करना।",
    "अपने मित्रों के समूह में सामंजस्य बनाए रखें।",
    "अपने सेनपई के साथ उसके रिश्ते की खोज।"
  ],
