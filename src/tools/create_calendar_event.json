{
  "type": "function",
  "function": {
    "name": "create_calendar_event",
    "description": "Crea un nuovo evento nel Google Calendar.",
    "parameters": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Titolo dell'evento."
        },
        "start_time": {
          "type": "string",
          "description": "Data e ora di inizio in formato ISO 8601 (es. '2026-03-31T15:00:00Z')."
        },
        "end_time": {
          "type": "string",
          "description": "Data e ora di fine in formato ISO 8601."
        },
        "description": {
          "type": "string",
          "description": "Descrizione opzionale dell'evento."
        },
        "location": {
          "type": "string",
          "description": "Luogo opzionale dell'evento."
        }
      },
      "required": [
        "summary",
        "start_time",
        "end_time"
      ]
    }
  }
}