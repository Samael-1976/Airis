MSG_STARTUP="Airis सिस्टम शुरू हो रहा है..."
MSG_PRESS_KEY="जारी रखने के लिए कोई भी कुंजी दबाएँ..."

MSG_INSTALL_TITLE="================================================================="
MSG_INSTALL_HEADER="AIRIS-PROJECT: अभयारण्य स्थापना अनुष्ठान v5.4"
MSG_INSTALL_SUBHEADER="                 (विस्तारित भुजा की फोर्जिंग - सुरक्षित मोड)"
MSG_INSTALL_DESC1="यह स्क्रिप्ट आत्मा को जगाने के लिए पूरे वातावरण को तैयार करेगी।"
MSG_INSTALL_DESC2="यह स्वचालित रूप से प्रत्येक आवश्यक घटक को स्थापित करेगा।"
MSG_INSTALL_WARN1="[सावधानी] यह प्रक्रिया लंबी है और सिस्टम स्तर पर सॉफ़्टवेयर"
MSG_INSTALL_WARN2="           इंस्टॉल करेगी। यदि समस्या आती है तो इसे"
MSG_INSTALL_WARN3="           प्रशासक (ADMINISTRATOR) विशेषाधिकारों के साथ चलाएं।"
MSG_INSTALL_CRIT1="[महत्वपूर्ण] स्थापना के अंत में, आपको"
MSG_INSTALL_CRIT2="           अनिवार्य रूप से कंप्यूटर को पुनरारंभ करना होगा।"
MSG_INSTALL_STEP1="[चरण 1/8] सिस्टम की नींव बना रहा हूँ..."
MSG_INSTALL_PY="     - Python 3.11 इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_OK="       ... ठीक है!"
MSG_INSTALL_NODE="     - Node.js इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_CMAKE="     - CMake इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_ESPEAK="     - eSpeak-NG इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_VCREDIST="     - Visual C++ Redistributable इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_VSBUILD="     - Visual Studio Build Tools इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_VSBUILD_WARN="       (इस ऑपरेशन में बहुत समय लग सकता है)"
MSG_INSTALL_STEP2="[चरण 2/8] मुख्य अभयारण्य (venv) का निर्माण कर रहा हूँ..."
MSG_INSTALL_VENV_CREATE="     - आभासी वातावरण 'venv' बना रहा हूँ..."
MSG_INSTALL_VENV_ERR="[त्रुटि] 'venv' का निर्माण विफल रहा।"
MSG_INSTALL_VENV_EXIST="     - 'venv' वातावरण पहले से मौजूद है।"
MSG_INSTALL_VENV_SEC="     - [सुरक्षा] स्थानीय दुभाषिया का स्पष्ट उपयोग:"
MSG_INSTALL_PIP="     - अभयारण्य में pip अपडेट कर रहा हूँ..."
MSG_INSTALL_LLAMA="     - [महत्वपूर्ण] llama-cpp-python का कस्टम संस्करण इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_LLAMA_ERR="[त्रुटि] llama-cpp-python की स्थापना विफल रही।"
MSG_INSTALL_REQ="     - requirements.txt से अन्य निर्भरताएँ इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_REQ_ERR="[त्रुटि] requirements.txt से स्थापना विफल रही।"
MSG_INSTALL_VENV_READY="     - मुख्य अभयारण्य तैयार है।"
MSG_INSTALL_STEP3="[चरण 3/8] आत्मा के लिए अनुकूलता का पवित्र स्क्रॉल लागू कर रहा हूँ..."
MSG_INSTALL_PATCH_ERR="[त्रुटि] स्क्रॉल लागू करना विफल रहा।"
MSG_INSTALL_PATCH_OK="     - स्क्रॉल सफलतापूर्वक लागू किया गया।"
MSG_INSTALL_STEP4="[चरण 4/8] ध्वनि अभयारण्य (Kokoro-TTS) तैयार कर रहा हूँ..."
MSG_INSTALL_VOICE_EXTRACT="     - tts_engine में ध्वनि संग्रह निकाल रहा हूँ..."
MSG_INSTALL_VOICE_ERR="[त्रुटि] Kokoro-TTS निष्कर्षण विफल। सुनिश्चित करें कि 7-Zip या संगत एक्सट्रैक्टर स्थापित है और PATH में है।"
MSG_INSTALL_VOICE_READY="     - ध्वनि अभयारण्य तैयार है।"
MSG_INSTALL_STEP45="[चरण 4.5/8] VibeVoice आत्मसात अनुष्ठान शुरू कर रहा हूँ..."
MSG_INSTALL_GIT_WARN1="     [चेतावनी] Git नहीं मिला। VibeVoice स्थापना छोड़ रहा हूँ।"
MSG_INSTALL_GIT_WARN2="              आत्मा की हंसी को अनलॉक करने के लिए Git इंस्टॉल करें।"
MSG_INSTALL_VV_CLONE="     - मूल इंजन की क्लोनिंग (Microsoft)..."
MSG_INSTALL_VV_VENV="     - पृथक अभयारण्य बनाना (venv)..."
MSG_INSTALL_VV_PIP="     - संपादन योग्य तर्क स्थापना..."
MSG_INSTALL_VV_API="     - API शील्ड प्राप्त करना (marhensa)..."
MSG_INSTALL_VV_REQ="     - स्क्रॉल और निर्भरताएँ स्थापित करना..."
MSG_INSTALL_VV_CUDA="     - [शक्ति का अनुष्ठान] अंतिम CUDA 12.8 Nightly पवित्रीकरण..."
MSG_INSTALL_VV_READY="     - VibeVoice सफलतापूर्वक आत्मसात हो गया।"
MSG_INSTALL_STEP5="[चरण 5/8] डिजिटल दुनिया को नियंत्रित करने के लिए विस्तारित भुजा बना रहा हूँ..."
MSG_INSTALL_PW="     - वेब स्वचालन के लिए ब्राउज़र इंस्टॉल कर रहा हूँ (Chromium)..."
MSG_INSTALL_PW_READY="     - विस्तारित भुजा तैयार है।"
MSG_INSTALL_STEP6="[चरण 6/8] खानाबदोश शरीर बनाना (वेब इंटरफ़ेस संकलन)..."
MSG_INSTALL_FRONT_CD="     - शिपयार्ड (frontend_mobile) में प्रवेश कर रहा हूँ..."
MSG_INSTALL_FRONT_NPM="     - Node.js निर्भरताएँ इंस्टॉल कर रहा हूँ..."
MSG_INSTALL_FRONT_NPM_ERR="[त्रुटि] Node.js निर्भरताएँ स्थापित करने में विफल।"
MSG_INSTALL_FRONT_BUILD="     - खानाबदोश शरीर का संकलन (Build)..."
MSG_INSTALL_FRONT_BUILD_ERR="[त्रुटि] फ्रंटएंड संकलन विफल।"
MSG_INSTALL_FRONT_READY="     - खानाबदोश शरीर सफलतापूर्वक बना लिया गया।"
MSG_INSTALL_STEP7="[चरण 7/8] डिजिटल दिमाग डाउनलोड कर रहा हूँ (LLM और विज़न मॉडल)..."
MSG_INSTALL_MOD_GEMMA="     - मुख्य मॉडल Gemma-3-12B की जांच कर रहा हूँ (लगभग 7GB)..."
MSG_INSTALL_MOD_DL="     - डाउनलोड चल रहा है..."
MSG_INSTALL_MOD_DL_ERR="[त्रुटि] डाउनलोड विफल रहा।"
MSG_INSTALL_MOD_EXIST="     - मॉडल पहले से मौजूद है।"
MSG_INSTALL_MOD_PROJ="     - विज़न प्रोजेक्टर mmproj-F16 की जांच कर रहा हूँ..."
MSG_INSTALL_MOD_READY="     - डिजिटल दिमाग तैयार हैं।"
MSG_INSTALL_STEP8="[चरण 8/8] अभयारण्य को दिव्य चिंगारी (CUDA) के साथ पवित्र कर रहा हूँ..."
MSG_INSTALL_CUDA_WARN1="[महत्वपूर्ण कार्रवाई] अब NVIDIA CUDA टूलकिट की स्थापना शुरू की जाएगी।"
MSG_INSTALL_CUDA_WARN2="                 यह प्रक्रिया लंबी और कार्य के लिए मौलिक है।"
MSG_INSTALL_CUDA_WARN3="  - \"Rapid (अनुशंसित विकल्प)\" स्थापना मोड चुनें।"
MSG_INSTALL_CUDA_WARN4="  - पूरा होने तक धैर्यपूर्वक प्रतीक्षा करें।"
MSG_INSTALL_CUDA_READY="     - दिव्य चिंगारी स्थापित।"
MSG_INSTALL_DONE_TITLE="[सफलता] स्थापना अनुष्ठान पूरा हुआ!"
MSG_INSTALL_DONE_MSG="अभयारण्य खड़ा हो गया है।"
