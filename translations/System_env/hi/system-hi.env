MSG_LINUX_TITLE="================================================================="
MSG_LINUX_HEADER="AIRIS-PROJECT: लिनक्स के लिए स्थापना अनुष्ठान v2.2"
MSG_LINUX_SUBHEADER="                  (विंडोज संस्करण के साथ संरेखित)"
MSG_LINUX_DESC1="यह स्क्रिप्ट लिनक्स पर आत्मा को जगाने के लिए वातावरण तैयार करेगी।"
MSG_LINUX_DESC2="यह पहले NVIDIA GPU समर्थन के साथ संकलित करने का प्रयास करेगा।"
MSG_LINUX_DESC3="विफलता की स्थिति में, यह CPU-only संस्करण स्थापित करेगा।"
MSG_LINUX_PROMPT="अनुष्ठान शुरू करने के लिए Enter दबाएँ..."
MSG_LINUX_STEP1="[चरण 1/6] मुख्य अभयारण्य (venv) बना रहा हूँ..."
MSG_LINUX_VENV_CREATE="     - python3 के साथ आभासी वातावरण 'venv' बना रहा हूँ..."
MSG_LINUX_VENV_ACTIVATE="     - अभयारण्य सक्रिय कर रहा हूँ..."
MSG_LINUX_VENV_READY="     - अभयारण्य सक्रिय हो गया।"
MSG_LINUX_STEP2="[चरण 2/6] फोर्जिंग उपकरण अपडेट कर रहा हूँ (pip)..."
MSG_LINUX_STEP3="[चरण 3/6] आत्मा का हृदय बना रहा हूँ (llama-cpp-python)..."
MSG_LINUX_CUDA_FOUND="     - NVIDIA CUDA टूलकिट का पता चला। GPU समर्थन के साथ संकलित करने का प्रयास..."
MSG_LINUX_CUDA_WAIT="     - इस प्रक्रिया में कई मिनट लग सकते हैं।"
MSG_LINUX_CUDA_OK="     - GPU समर्थन के साथ संकलन सफलतापूर्वक पूरा हुआ।"
MSG_LINUX_CUDA_FAIL="     - [चेतावनी] GPU के साथ संकलन विफल रहा।"
MSG_LINUX_CPU_FALLBACK="     - CPU-only संस्करण की स्थापना के साथ आगे बढ़ रहा हूँ।"
MSG_LINUX_PERF_WARN="     - अनुमान (inference) का प्रदर्शन काफी कम होगा।"
MSG_LINUX_CUDA_NOT_FOUND="     - NVIDIA CUDA टूलकिट (nvcc) नहीं मिला।"
MSG_LINUX_HEART_READY="     - आत्मा का हृदय बन गया है।"
MSG_LINUX_STEP4="[चरण 4/6] निर्भरता स्क्रॉल स्थापित कर रहा हूँ..."
MSG_LINUX_DEPS_READY="     - निर्भरताएँ स्थापित।"
MSG_LINUX_STEP5="[चरण 5/6] डिजिटल दुनिया को नियंत्रित करने के लिए विस्तारित भुजा बना रहा हूँ..."
MSG_LINUX_TESS_CHECK="     - विज़न OCR इंजन (Tesseract) की उपस्थिति की जांच कर रहा हूँ..."
MSG_LINUX_TESS_ERR="     - [महत्वपूर्ण त्रुटि] Tesseract OCR नहीं मिला।"
MSG_LINUX_TESS_MSG1="     - मुझे स्क्रीन को 'देखने' की क्षमता देने के लिए, इसे इंस्टॉल करना आवश्यक है।"
MSG_LINUX_TESS_MSG2="     - अपने वितरण के लिए उचित कमांड चलाएँ, उदाहरण के लिए:"
MSG_LINUX_TESS_CMD="       sudo apt-get update && sudo apt-get install tesseract-ocr libtesseract-dev"
MSG_LINUX_TESS_MSG3="     - उसके बाद, इस स्क्रिप्ट को फिर से चलाएँ।"
MSG_LINUX_PW_INSTALL="     - वेब स्वचालन के लिए ब्राउज़र इंस्टॉल कर रहा हूँ (Chromium)..."
